# Supabase Configuration (Local Development Only)
# IMPORTANT: NEVER commit .env.local to version control
#
# Setup Instructions:
# 1. Copy this file to .env.local
# 2. Replace the placeholder values with your actual Supabase credentials
# 3. Get your credentials from: https://supabase.com
#    - Select your project
#    - Go to Settings → API
#    - Copy the Project URL and Anon/Public Key

# Your Supabase project URL
VITE_SUPABASE_URL=https://xxxxx.supabase.co

# Your Supabase anonymous/public key (safe to expose in frontend)  
# This key has limited permissions and is meant for browser use
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Google Gemini API (for AI-powered chat features)
VITE_GEMINI_API_KEY=AIzaSyC7Pw_VPm2mb3pEhFNaRCADEQlJsB7iFWo